# Adapty Public SDK Key (from Adapty Dashboard → App settings → General)
# For EAS production builds, set this in EAS Secrets: eas secret:create --name EXPO_PUBLIC_ADAPTY_PUBLIC_SDK_KEY --value "your_key"
EXPO_PUBLIC_ADAPTY_PUBLIC_SDK_KEY=your_public_sdk_key_here

# Placement "main" is used in code (Adapty Dashboard → Placements).
